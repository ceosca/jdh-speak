# Copy to .env (gitignored) and adjust. These are operator-only settings, never
# shown in the app UI.
#
# Two ways these reach the server:
#   - In development (`pnpm dev`) index.ts loads this .env at startup.
#   - In production, load it via systemd's EnvironmentFile= (see jdh-speak.service).
#     This is REQUIRED for the ANNOUNCED_IP* values below: mediasoup-config.ts
#     reads them at import time, before the app's own .env loader runs, so they
#     must already be in the environment or ICE falls back to 127.0.0.1 (no media).

# Display name of this instance — shown as the app title in the lobby heading
# and the browser tab. Rebrand your deployment by changing this and restarting
# the server (no rebuild needed). Defaults to "JDH Speak" when unset.
INSTANCE_NAME=JDH Speak

# HTTP/signaling port (the server serves the built client here too). Default 3100.
PORT=3100

# Set to production for production runs.
NODE_ENV=production

# Public IPv4 announced to ICE — REQUIRED in production for SFU media to connect.
# Remote participants send their audio here, so it must be your public IP and the
# WebRTC UDP port range (40000-40100) must be forwarded 1:1 to this host.
ANNOUNCED_IP=203.0.113.10

# Optional: LAN IP of this host. When set, the SFU also advertises this address,
# so participants on the same local network connect directly over the LAN (no NAT
# hairpin, lower latency). Leave unset if the server has no local clients.
ANNOUNCED_IP_LOCAL=192.168.1.50

# Optional: public IPv6 announced to ICE. Set only if this host has a globally
# reachable IPv6 address; otherwise leave unset (don't announce ULA/link-local).
# ANNOUNCED_IP6=2001:db8::1
