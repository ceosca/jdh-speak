# Copy to .env (gitignored) and adjust. Loaded at server startup from the repo
# root by server/src/index.ts. These are operator-only settings, never shown in
# the app UI.

# Display name of this instance — shown as the app title in the lobby heading
# and the browser tab. Rebrand your deployment by changing this and restarting
# the server (no rebuild needed). Defaults to "SonicRoom" when unset.
INSTANCE_NAME=SonicRoom

# Off-box "noty" notifications (server/src/notify.ts): when a PUBLIC room is
# created or someone joins one, send a notification to a noty daemon — a raw-TCP
# service that speaks it aloud (screen-reader / TTS) and plays a sound.
# Disabled unless NOTY_ENABLED is truthy, so leaving this file as-is is a no-op.
NOTY_ENABLED=false
NOTY_HOST=win.oriolgomez.com
NOTY_PORT=1337
NOTY_SENDER=sonicroom
