# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment
.env
.env.local
.env.*.local

# Editor / OS
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Vite
.vite/

# Coverage / cache
coverage/
.cache/
.eslintcache
.parcel-cache/

# Runtime
*.pid
*.seed
*.pid.lock

# Local Claude Code dev config (preview launch.json, etc.)
.claude/

# Operator-provided event sounds: the audio files are per-deployment (dropped on
# the server), so they're not versioned — but keep the README that documents them.
sounds/*
!sounds/README.md

# Operator-provided live-TV channel list (may hold DRM keys) + the standalone tool
/tv/*
!/tv/README.md
# db.json holds DRM ClearKeys — versioned ONLY because this repo is PRIVATE.
# If the repo is ever made public again, remove this line and purge it from history.
!/tv/db.json

# Serieteca reference material (series.json is fetched from archive.org at runtime)
/serieteca/

# Built-in ambience impulses live in client/public/ir/ (tracked, .ogg). EXTRA
# operator-dropped impulses go in a dedicated repo-root ir/ (AMBIENCE_IR_DIR) —
# per-box, not committed. Also guard client/public/ir against a heavy raw pack
# being committed by accident (it'd bloat the repo and client/dist).
/ir/
client/public/ir/*.wav
client/public/ir/*.flac
client/public/ir/*.aac
client/public/ir/*.m4a
