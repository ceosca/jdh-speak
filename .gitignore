# Operator-provided event sounds: the audio files are per-deployment (dropped on
# the server), so they're not versioned — but keep the README that documents them.
sounds/*
!sounds/README.md

# Operator-provided live-TV channel list (may hold DRM keys) + the standalone tool
/tv/*
!/tv/README.md
# db.json holds DRM ClearKeys — versioned ONLY because this repo is PRIVATE.
# If the repo is ever made public again, remove this line and purge it from history.
!/tv/db.json
